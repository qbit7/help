<Window x:Class="projectName.admin.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:projectName.admin"
        mc:Ignorable="d"
        Title="Окно Пользователя"
	    WindowStartupLocation="CenterScreen"
	    Height="1080" Width="1920"
	    MinHeight="650" MinWidth="800">
    <Grid Margin="20">
        <StackPanel>

            <TextBlock x:Name="AdminInfoTextBlock" Text="Панель управления пользователями" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <Grid x:Name="mainGrid" Visibility="Visible">
                <StackPanel>
                    <DataGrid x:Name="UsersDataGrid" Height="350" Width="700" AutoGenerateColumns="False" 
                              IsReadOnly="True" SelectionMode="Single" Background="White" BorderBrush="Gray" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Создать пользователя" Width="190" Height="35" Margin="0,0,10,0" Click="CreateUserBTN_Click"/>
                        <Button Content="Редактировать пользователя" Width="230" Height="35" Margin="0,0,10,0" Click="EditUserBTN_Click"/>
                        <Button Content="Удалить пользователя" Width="200" Height="35" Background="#FFE25353" Foreground="White" Click="DeleteUserBTN_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid x:Name="formGrid" Visibility="Collapsed">
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="20" Background="#FFF9F9F9">
                    <StackPanel Width="400" HorizontalAlignment="Center">

                        <TextBlock x:Name="FormTitleTextBlock" Text="Создание нового пользователя" FontSize="16" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                        <TextBlock Text="Логин" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox x:Name="formLoginTextBox" Height="30" Width="300" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Пароль" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox x:Name="formPasswordTextBox" Height="30" Width="300" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Роль" Foreground="Gray" Margin="0,0,0,5"/>
                        <ComboBox x:Name="formRoleComboBox" Height="30"  Width="300" Margin="0,0,0,25" 
                                  DisplayMemberPath="Name" SelectedValuePath="Id" VerticalContentAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="SaveFormBTN" Content="Сохранить" Width="120" Height="35" Margin="0,0,20,0" Click="SaveFormBTN_Click"/>
                            <Button Content="Отмена" Width="120" Height="35" Click="CancelFormBTN_Click"/>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </Grid>
</Window>
